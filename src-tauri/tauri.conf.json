{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "像素小龙",
  "version": "1.0.0",
  "identifier": "com.desktoppet.dragon",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "像素小龙",
        "width": 200,
        "height": 200,
        "transparent": true,
        "alwaysOnTop": true,
        "decorations": false,
        "resizable": false,
        "maximizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "像素小龙桌面宠物"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
